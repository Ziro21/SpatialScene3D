# ============================================================
# .gitignore — scene3d
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# --- Virtual Environment ---
venv/
.venv/
env/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# --- Large intermediate / generated data (no marking value) ---
data/
outputs/
outputs-v6/
outputs-v7/
outputs-v8/
output-v7.5/
outputs-v10.5/
room_frames.zip
temp_data.zip
*.zip

# --- Heavy final scene PLYs that exceed GitHub's 100MB limit ---
# The full + semantic PLYs (>100MB each) cannot be pushed. The pruned viewer
# PLY (90MB) IS tracked via LFS so the scene can still be loaded in the viewer.
final_full_scene_package/scene_outputs/splat_final.ply
final_full_scene_package/scene_outputs/splat_semantic.ply
final_full_scene_package v10.5/scene_outputs/splat_final.ply
final_full_scene_package v10.5/scene_outputs/splat_semantic.ply

# --- Model Weights (downloaded separately) ---
checkpoints/
*.pt
*.pth
*.bin
*.safetensors

# --- Secrets (NEVER commit) ---
.env
*.key
secrets.json

# --- Temporary ---
*.log
.mypy_cache/
.pytest_cache/

# --- Keep these tracked ---
!assets/videos/*.mp4
!eval/results.json
